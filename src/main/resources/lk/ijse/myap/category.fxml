<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.myap.controller.CategoryController">
   <children>
      <VBox alignment="CENTER" prefHeight="52.0" prefWidth="802.0" style="-fx-background-color: #fc72dc;">
         <children>
            <Label text="Category Manage">
               <font>
                  <Font name="System Bold Italic" size="23.0" />
               </font>
            </Label>
         </children>
      </VBox>
      <VBox layoutX="1.0" layoutY="52.0" prefHeight="549.0" prefWidth="802.0">
         <children>
            <Pane prefHeight="255.0" prefWidth="802.0">
               <children>
                  <VBox layoutX="98.0" layoutY="24.0" prefHeight="52.0" prefWidth="190.0" style="-fx-background-color: white;">
                     <children>
                        <Label text="ctId" />
                        <TextField fx:id="idField" onKeyPressed="#handleSearchCategory" />
                     </children>
                  </VBox>
                  <VBox layoutX="461.0" layoutY="24.0" prefHeight="52.0" prefWidth="190.0" style="-fx-background-color: white;">
                     <children>
                        <Label text="ctName" />
                        <TextField fx:id="nameField" />
                     </children>
                  </VBox>
                  <HBox layoutX="163.0" layoutY="108.0" prefHeight="100.0" prefWidth="511.0">
                     <children>
                        <Button mnemonicParsing="false" onAction="#handleSaveCategory" prefHeight="30.0" prefWidth="70.0" style="-fx-background-color: #32fa46;" text="Save">
                           <HBox.margin>
                              <Insets left="10.0" right="10.0" />
                           </HBox.margin>
                           <font>
                              <Font name="Arial Black" size="11.0" />
                           </font>
                        </Button>
                        <Button layoutX="10.0" layoutY="10.0" mnemonicParsing="false" onAction="#handleCategoryUpdate" prefHeight="30.0" prefWidth="70.0" style="-fx-background-color: yellow;" text="Update">
                           <HBox.margin>
                              <Insets left="10.0" right="10.0" />
                           </HBox.margin>
                           <font>
                              <Font name="Arial Black" size="11.0" />
                           </font>
                        </Button>
                        <Button layoutX="62.0" layoutY="10.0" mnemonicParsing="false" onAction="#handleCategoryDelete" prefHeight="30.0" prefWidth="70.0" style="-fx-background-color: red;" text="Delete">
                           <HBox.margin>
                              <Insets left="10.0" right="10.0" />
                           </HBox.margin>
                           <font>
                              <Font name="Arial Black" size="11.0" />
                           </font>
                        </Button>
                        <Button layoutX="114.0" layoutY="10.0" mnemonicParsing="false" onAction="#handleReset" prefHeight="30.0" prefWidth="70.0" style="-fx-background-color: blue;" text="Reset">
                           <HBox.margin>
                              <Insets left="10.0" right="10.0" />
                           </HBox.margin>
                           <font>
                              <Font name="Arial Black" size="11.0" />
                           </font>
                        </Button>
                     </children>
                  </HBox>
               </children></Pane>
            <Pane layoutX="10.0" layoutY="10.0" prefHeight="313.0" prefWidth="802.0">
               <children>
                  <TableView fx:id="tblCategory" layoutX="162.0" layoutY="25.0" prefHeight="200.0" prefWidth="450.0">
                    <columns>
                      <TableColumn fx:id="colId" prefWidth="196.0" text="ctId" />
                      <TableColumn fx:id="colName" prefWidth="253.60003662109375" text="ctName" />
                    </columns>
                  </TableView>
               </children></Pane>
         </children>
      </VBox>
   </children>
</AnchorPane>
