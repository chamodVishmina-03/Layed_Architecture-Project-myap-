<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.myap.controller.EmployeeController">
   <children>
      <VBox alignment="CENTER" prefHeight="56.0" prefWidth="800.0" style="-fx-background-color: #fc72dc;">
         <children>
            <Label text="Employee Manage">
               <font>
                  <Font name="System Bold Italic" size="23.0" />
               </font>
            </Label>
         </children>
      </VBox>
      <VBox layoutX="1.0" layoutY="55.0" prefHeight="545.0" prefWidth="800.0">
         <children>
            <Pane prefHeight="266.0" prefWidth="800.0">
               <children>
                  <VBox layoutX="45.0" layoutY="19.0" prefHeight="43.0" prefWidth="188.0" style="-fx-background-color: white;">
                     <children>
                        <Label text="EmID" />
                        <TextField fx:id="idField" onKeyPressed="#handleSearchEmployee" />
                     </children>
                  </VBox>
                  <VBox layoutX="45.0" layoutY="76.0" prefHeight="34.0" prefWidth="188.0" style="-fx-background-color: white;">
                     <children>
                        <Label text="EmName" />
                        <TextField fx:id="nameField" />
                     </children>
                  </VBox>
                  <VBox layoutX="306.0" layoutY="79.0" prefHeight="43.0" prefWidth="188.0" style="-fx-background-color: white;">
                     <children>
                        <Label text="Salary" />
                        <TextField fx:id="salaryField" />
                     </children>
                  </VBox>
                  <VBox layoutX="306.0" layoutY="16.0" prefHeight="43.0" prefWidth="188.0" style="-fx-background-color: white;">
                     <children>
                        <Label text="Role" />
                        <TextField fx:id="roleField" prefHeight="13.0" prefWidth="188.0" />
                     </children>
                  </VBox>
                  <HBox alignment="CENTER" layoutX="106.0" layoutY="140.0" prefHeight="90.0" prefWidth="552.0">
                     <children>
                        <Button mnemonicParsing="false" onAction="#handleSaveEmployee" prefHeight="30.0" prefWidth="70.0" style="-fx-background-color: #32fa46;" text="Save">
                           <HBox.margin>
                              <Insets left="10.0" right="10.0" />
                           </HBox.margin>
                           <font>
                              <Font name="Arial Black" size="12.0" />
                           </font>
                        </Button>
                        <Button layoutX="10.0" layoutY="10.0" mnemonicParsing="false" onAction="#handleEmployeeUpdate" prefHeight="30.0" prefWidth="70.0" style="-fx-background-color: yellow;" text="Update ">
                           <HBox.margin>
                              <Insets left="10.0" right="10.0" />
                           </HBox.margin>
                           <font>
                              <Font name="Arial Black" size="12.0" />
                           </font>
                        </Button>
                        <Button layoutX="62.0" layoutY="10.0" mnemonicParsing="false" onAction="#handleEmployeeDelete" prefHeight="30.0" prefWidth="70.0" style="-fx-background-color: red;" text="Delete">
                           <HBox.margin>
                              <Insets left="10.0" right="10.0" />
                           </HBox.margin>
                           <font>
                              <Font name="Arial Black" size="12.0" />
                           </font>
                        </Button>
                        <Button layoutX="114.0" layoutY="10.0" mnemonicParsing="false" onAction="#handleReset" prefHeight="30.0" prefWidth="70.0" style="-fx-background-color: blue;" text="Reset">
                           <HBox.margin>
                              <Insets left="10.0" right="10.0" />
                           </HBox.margin>
                           <font>
                              <Font name="Arial Black" size="12.0" />
                           </font>
                        </Button>
                     </children></HBox>
                  <VBox layoutX="547.0" layoutY="19.0" prefHeight="43.0" prefWidth="188.0" style="-fx-background-color: white;">
                     <children>
                        <Label text="Tele" />
                        <TextField fx:id="teleField" />
                     </children>
                  </VBox>
               </children>
            </Pane>
            <Pane layoutX="10.0" layoutY="10.0" prefHeight="278.0" prefWidth="800.0">
               <children>
                  <TableView fx:id="tblEmployee" layoutX="11.0" layoutY="14.0" prefHeight="200.0" prefWidth="779.0">
                    <columns>
                      <TableColumn fx:id="colId" prefWidth="104.0" text="emId" />
                      <TableColumn fx:id="colName" prefWidth="159.20001220703125" text="emName" />
                        <TableColumn fx:id="colRole" prefWidth="201.5999755859375" text="role" />
                        <TableColumn fx:id="colSalary" prefWidth="148.00006103515625" text="salary" />
                        <TableColumn fx:id="colTele" prefWidth="166.39996337890625" text="tele" />
                    </columns>
                  </TableView>
               </children></Pane>
         </children>
      </VBox>
   </children>
</AnchorPane>
