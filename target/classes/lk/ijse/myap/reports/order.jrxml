<jasperReport name="order" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="e0a4d2ce-72e9-4c6d-9152-5e597f454ee2">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="MYSQL"/>
	<parameter name="p_orderId" class="java.lang.String"/>
	<query language="SQL"><![CDATA[SELECT 
    o.orderId,
    o.totalPrice,
    oi.itemId,
    i.itemName,
    oi.orderQty,
    oi.unitPrice,
    oi.lineTotal
FROM orders o
JOIN order_item oi ON o.orderId = oi.orderId
JOIN item i ON oi.itemId = i.itemId
WHERE o.orderId = $P{p_orderId}]]></query>
